{
  "bead_id": "B-0f499d78",
  "title": "Strengthen tester guardrail against background task misuse",
  "agent_type": "developer",
  "description": "The tester guardrail template (templates/agents/tester.md) already prohibits run_in_background but agents keep violating it. The failure mode: agent runs tests in background, receives a task-notification, then claims structured output was already submitted and ends without emitting JSON. Fix: (1) move the run_in_background prohibition to the very top of the template before any other content; (2) add explicit instruction: if a task-notification appears in context, the constraint was violated \u2014 re-run the test synchronously and emit JSON as the final response; (3) add a final-action reminder that the JSON verdict block must be the absolute last output of the response.",
  "status": "in_progress",
  "bead_type": "task",
  "parent_id": null,
  "dependencies": [],
