  "acceptance_criteria": [
    "--status in_progress returns only in-progress beads",
    "--status ready --status blocked returns beads matching either status (OR)",
    "--agent tester returns only tester beads",
    "--agent developer --agent recovery returns beads matching either agent type",
    "--feature-root B-xxxx returns only beads with that feature_root_id",
    "--feature-root supports prefix resolution",
